{
  "base_url": "https://www.samsung.com/sec",
  "search_url": "https://www.samsung.com/sec/search/?searchBy={model}",
  "selectors": {
    "search_result": [
      ".aisearch-product__name a",
      ".aisearch-product__name",
      ".sc-g-product-card__info-title a",
      ".sc-product-card__title a",
      ".product-card a"
    ],
    "spec_section_trigger": [
      "a[href='#specification']",
      "#acompGoodsFeatures + a",
      ".revamp-scrollspy-link:nth-of-type(2)",
      "button[data-tab='specification']"
    ],
    "spec_label": [
      ".v-spec-details__label",
      ".spec-list__title",
      ".specification-title",
      ".spec_title",
      "dt"
    ],
    "spec_value": [
      ".v-spec-details__value",
      ".spec-list__description",
      ".specification-value",
      ".spec-value",
      ".spec_desc",
      "dd"
    ],
    "price": [
      ".pd-buying-price__price span:first-child",
      "p.price-after",
      ".pd-buying-price__price"
    ]
  }
}
